# Webortex Ledger Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Setup
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/webortex_ledger?retryWrites=true&w=majority

# JWT Authentication Setup
JWT_SECRET=super_secret_webortex_ledger_jwt_key_30d

# Cloudinary Setup (Optional - fallbacks to disk storage if empty)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
